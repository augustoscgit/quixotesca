# Force PHP 8.0 on Locaweb shared hosting.
# The modules use PHP 8 features such as str_starts_with().
# AddHandler php80-script .php

AddHandler php80-script .php
#suPHP_ConfigPath /home/quixotesca

DirectoryIndex index.php index.html
Options -Indexes

# Protect sensitive files and generated artifacts.
<FilesMatch "(^\.|\.md$|\.env$|\.sql$|\.bak$|\.backup$|\.dump$|\.log$|\.sqlite$|\.sqlite3$|\.db$|\.zip$|\.rar$|\.7z$)">
  Require all denied
  Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^(\.git|\.agents|\.codex|docs|includes|scratch|_archive|secrets|carex/(config|src|tools|docs|secrets|private)|cat/(database|docs|src)|fichario/(private|secrets|data|docs|system_md|tests)|investigacao/docs|ldrt/(docs|secrets|database))(/|$) - [R=404,L]
</IfModule>

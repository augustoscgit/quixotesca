# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.renastonline.org/fichario
# Keep false unless the public deployment is ready to be indexed by search engines.
APP_ALLOW_INDEXING=false

# Database: current application profile (PostgreSQL via PDO)
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=

# External AI API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Shared access module
ACCESS_APP_URL=https://www.renastonline.org/acesso
ACCESS_DB_SCHEMA=acesso

# PHP sessions
# SESSION_IDLE_TIMEOUT is the inactivity lifetime in seconds. Default: 14400 (4 hours).
SESSION_IDLE_TIMEOUT=14400
# Empty temporary session files older than this are removed. Default: 900 (15 minutes).
SESSION_EMPTY_FILE_TIMEOUT=900
# Native PHP session GC probability. Defaults keep cleanup light on shared hosting.
SESSION_NATIVE_GC_PROBABILITY=1
SESSION_NATIVE_GC_DIVISOR=100
# App-level session cleanup runs at most once per interval and only by probability.
SESSION_APP_GC_PROBABILITY=1
SESSION_APP_GC_DIVISOR=100
SESSION_APP_GC_INTERVAL=3600

# Optional notifications
TOKEN_TELEGRAM=
CHAT_ID_TELEGRAM=

# Optional deployment
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_PATH=
